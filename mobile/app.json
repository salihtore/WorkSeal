{
  "expo": {
    "name": "WorkSeal",
    "slug": "workseal",
    "version": "2.0.0",
    "scheme": "workseal",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050810",
    "platforms": ["ios", "android"],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050810"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "workseal" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.workseal.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["slush", "suiwallet"]
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
